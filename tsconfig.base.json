{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@vendor/custom-module": ["libs/vendor/custom-module/index.ts"],
      "@umn-nde/base-view": ["libs/base-view/src/index.ts"],
      "@umn-nde/collection-discovery": [
        "libs/collection-discovery/src/index.ts"
      ],
      "@umn-nde/full-display": ["libs/full-display/src/index.ts"],
      "@umn-nde/shared-state": ["libs/shared/state/src/index.ts"],
      "@umn-nde/shared-state/view-config": [
        "libs/shared/state/view-config/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
